{
  "name": "@gutenku/server",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "pnpm --filter @gutenguess/server run build || true && tsc -p tsconfig.json && tsc-alias",
    "start": "tsx src/index.ts",
    "start:dist": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "oxlint --fix",
    "typecheck": "tsc --noEmit",
    "setup:books": "tsx src/cli/setup-books.ts",
    "setup:books:reset": "tsx src/cli/setup-books.ts --reset",
    "extract": "LOG_LEVEL=warn tsx src/cli/extract-haiku.ts",
    "ga:evolve": "tsx src/cli/ga-evolution.ts",
    "ga:benchmark": "tsx src/cli/ga-benchmark.ts",
    "ml:train": "tsx src/cli/ml-train.ts",
    "ml:collect": "bash scripts/collect-training-data.sh",
    "mc:train": "tsx src/cli/markov-train.ts",
    "fetch:classics": "tsx src/cli/fetch-gutenberg-classics.ts",
    "post": "tsx src/cli/post-haiku.ts",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@apollo/server": "^5.5.1",
    "@as-integrations/express5": "^1.1.2",
    "@graphql-tools/schema": "^10.0.33",
    "@gutenku/shared": "workspace:*",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-node": "^4.22.0",
    "axios": "^1.16.1",
    "body-parser": "^2.2.2",
    "canvas": "^3.2.3",
    "cli-progress": "^3.12.0",
    "commander": "^14.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "form-data": "^4.0.5",
    "global": "^4.4.0",
    "graphql": "^16.14.0",
    "graphql-subscriptions": "^3.0.0",
    "graphql-ws": "^6.0.8",
    "helmet": "^8.2.0",
    "log-update": "^8.0.0",
    "mongo-sanitize": "^1.1.0",
    "mongoose": "^9.6.2",
    "natural": "^8.1.1",
    "node-fetch": "^3.3.2",
    "openai": "^6.39.0",
    "ora": "^9.4.0",
    "picocolors": "^1.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "seedrandom": "^3.0.5",
    "sharp": "^0.34.5",
    "string-width": "^8.2.1",
    "syllable": "^5.0.1",
    "terminal-image": "^4.3.0",
    "tsyringe": "^4.10.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.6",
    "@types/cli-progress": "^3.11.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/node-fetch": "^2.6.13",
    "@types/seedrandom": "^3.0.8",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-istanbul": "^4.1.7",
    "@vitest/coverage-v8": "4.1.7",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "optionalDependencies": {
    "@gutenguess/server": "file:../../private/gutenguess/packages/server"
  },
  "licence": "UNLICENSED"
}
