{
  "name": "@gutenku/front",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite-ssg build",
    "start": "vite serve --host",
    "preview": "vite preview",
    "test": "pnpm test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "cypress run",
    "test:a11y": "cypress run --spec 'cypress/e2e/accessibility.cy.ts'",
    "test:gui": "cypress run --headed --no-exit",
    "lint": "oxlint --fix",
    "lint:css": "stylelint 'src/**/*.{vue,scss,css}'",
    "typecheck": "vue-tsc --noEmit",
    "lighthouse": "vite build && lhci autorun",
    "cap:build": "pnpm build && npx cap sync",
    "cap:ios": "npx cap open ios",
    "cap:android": "npx cap open android",
    "cap:sync": "npx cap sync",
    "generate:assets": "npx tsx scripts/generate-capacitor-assets.ts",
    "cap:assets": "pnpm generate:assets && npx capacitor-assets generate",
    "generate:rss": "tsx scripts/generate-rss.ts"
  },
  "dependencies": {
    "@capacitor-community/safe-area": "^8.0.1",
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@chenglou/pretext": "^0.0.7",
    "@fingerprintjs/botd": "^2.0.0",
    "@gutenku/shared": "workspace:*",
    "@unhead/vue": "^2.1.15",
    "@urql/vue": "^2.1.0",
    "@vueuse/core": "^14.3.0",
    "@vueuse/motion": "^3.0.3",
    "graphql": "^16.14.0",
    "graphql-ws": "^6.0.8",
    "katex": "^0.16.47",
    "lucide-vue-next": "^0.577.0",
    "marked": "^18.0.4",
    "mermaid": "^11.15.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.4",
    "vue-router": "^5.0.7",
    "workbox-window": "^7.4.1"
  },
  "devDependencies": {
    "@babel/types": "^7.29.0",
    "@capacitor/assets": "^3.0.5",
    "@intlify/unplugin-vue-i18n": "^11.2.3",
    "@lhci/cli": "^0.15.1",
    "@types/node": "^25.9.1",
    "@types/webfontloader": "^1.6.38",
    "@types/zen-observable": "^0.8.7",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "4.1.7",
    "@vue/test-utils": "^2.4.10",
    "axe-core": "^4.11.4",
    "beasties": "^0.4.2",
    "cypress": "^15.15.0",
    "cypress-axe": "^1.7.0",
    "jsdom": "^29.1.1",
    "postcss-html": "^1.8.1",
    "purgecss": "^8.0.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass-embedded": "^1.99.0",
    "sass-loader": "^17.0.0",
    "sharp": "^0.34.5",
    "stylelint": "^17.12.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-imagemin": "^0.6.1",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-webfont-dl": "^3.12.0",
    "vite-ssg": "^28.3.0",
    "vitest": "^4.1.7",
    "vue-tsc": "^3.3.1"
  },
  "licence": "UNLICENSED"
}
